{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "diagnose-*.ts",
    "check-*.ts",
    "fix-*.ts",
    "migrate-*.ts",
    "migrate.ts",
    "repair-*.ts",
    "test-*.ts",
    "update-*.ts",
    "utils/resetDatabase.ts"
  ]
}
